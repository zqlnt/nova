# =============================================================================
# Local setup: copy this file to `.env.local` and fill values (`.env*.local` is gitignored).
# =============================================================================
#
# Next.js loads `.env.local` automatically. Variables are split as follows:
#
# • NEXT_PUBLIC_*  — exposed to the browser; embedded at `next build` time.
#   Required for Firebase client SDK. On Render, set the SAME keys in the service
#   Environment so they exist during `npm run build` (not only at runtime).
#
# • No NEXT_PUBLIC_  — server-only (API routes, Route Handlers); never sent to the client.
#   Use for LLM keys, webhooks, etc.
#
# =============================================================================

# --- Firebase (Web app — Project settings → Your apps → SDK setup) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional (Analytics)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firestore: if Rules are "allow if false" for everything, the app will stay empty.
# Use the rules in ./firestore.rules (Firebase Console → Firestore → Rules → Publish).

# --- LLM / server-only (do NOT use NEXT_PUBLIC_ — keep secret) ---
# Used by app/api/chat/route.ts and app/api/teacher/student-agent/route.ts
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# --- Optional org / Firestore (see lib/orgFirestore.ts, lib/orgService.ts) ---
# NEXT_PUBLIC_NOVA_ORG_ID=
# Firestore seed when `students` subcollection is empty:
# - Local `next dev`: seeding runs automatically unless you set this to false.
# - Production (`next build` / hosting): set to true once so GCSE/org demo data is written, then you may turn it off.
# NEXT_PUBLIC_FIRESTORE_SEED_ON_EMPTY=true
# NEXT_PUBLIC_FIRESTORE_SEED_ON_EMPTY=false

# --- Firebase Admin (scripts/import-gcse-firestore.ts only — server/CLI, not Next.js) ---
# Path to service account JSON from Firebase Console → Project settings → Service accounts
# GOOGLE_APPLICATION_CREDENTIALS=
# Optional override for import script (default org_ttutors)
# NOVA_ORG_ID=org_ttutors
