# =============================================================================
# Local setup: copy this file to `.env.local` and fill values (`.env*.local` is gitignored).
# =============================================================================
#
# Next.js loads `.env.local` automatically. Variables are split as follows:
#
# • NEXT_PUBLIC_*  — exposed to the browser; embedded at `next build` time.
#   Required for Firebase client SDK. On Render, set the SAME keys in the service
#   Environment so they exist during `npm run build` (not only at runtime).
#
# • No NEXT_PUBLIC_  — server-only (API routes, Route Handlers); never sent to the client.
#   Use for LLM keys, webhooks, etc.
#
# =============================================================================

# --- Firebase (Web app — Project settings → Your apps → SDK setup) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional (Analytics)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- LLM / server-only (do NOT use NEXT_PUBLIC_ — keep secret) ---
# Used by app/api/chat/route.ts and app/api/teacher/student-agent/route.ts
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# --- Optional org / Firestore (see lib/orgFirestore.ts) ---
# NEXT_PUBLIC_NOVA_ORG_ID=
# NEXT_PUBLIC_FIRESTORE_SEED_ON_EMPTY=
